{
  "name": "@movk/mapbox",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@11.7.0",
  "description": "声明式 Mapbox GL v3 封装库：MapboxMap/Source/Layer 等组件与 composables，原生支持 Nuxt 4 模块，并通过 Vite 插件在纯 Vue + Vite 项目中可用。内置 3D 建筑、雷达/扩散/辉光等动态效果，fog/terrain/天气环境，绘制（mapbox-gl-draw）、天地图、WMS/WMTS 与多坐标系本土化支持。",
  "author": "YiXuan <mhaibaraai@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhaibaraai/movk-mapbox.git"
  },
  "homepage": "https://mapbox.mhaibaraai.cn",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "bugs": {
    "url": "https://github.com/mhaibaraai/movk-mapbox/issues"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt4",
    "vue",
    "vite",
    "mapbox",
    "mapbox-gl",
    "map",
    "gis",
    "tianditu",
    "mapbox-gl-draw",
    "composables"
  ],
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "style": "./dist/runtime/index.css",
      "import": "./dist/module.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./unplugin": {
      "types": "./dist/unplugin.d.mts",
      "import": "./dist/unplugin.mjs"
    },
    "./vue-plugin": {
      "types": "./dist/vue-plugin.d.mts",
      "import": "./dist/vue-plugin.mjs"
    },
    "./index.css": "./dist/runtime/index.css",
    "./runtime/*": "./dist/runtime/*",
    "./components/*": "./dist/runtime/components/*",
    "./utils/*": {
      "types": [
        "./dist/runtime/utils/*.d.mts",
        "./dist/runtime/utils/*.d.ts",
        "./dist/runtime/utils/*.ts"
      ],
      "import": "./dist/runtime/utils/*"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.mts"
      ],
      "vite": [
        "./dist/vite.d.mts"
      ],
      "unplugin": [
        "./dist/unplugin.d.mts"
      ],
      "vue-plugin": [
        "./dist/vue-plugin.d.mts"
      ],
      "runtime/*": [
        "./dist/runtime/*"
      ],
      "components/*": [
        "./dist/runtime/components/*"
      ],
      "utils/*": [
        "./dist/runtime/utils/*.d.mts",
        "./dist/runtime/utils/*.ts"
      ]
    }
  },
  "style": "./dist/runtime/index.css",
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@mapbox/mapbox-gl-draw": ">=1.4.0",
    "lottie-web": ">=5.0.0",
    "mapbox-gl": ">=3.0.0",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "@mapbox/mapbox-gl-draw": {
      "optional": true
    },
    "lottie-web": {
      "optional": true
    }
  },
  "scripts": {
    "prepack": "pnpm build",
    "build": "nuxt-module-build build",
    "dev": "nuxt dev playgrounds/play",
    "dev:build": "nuxt build playgrounds/play",
    "dev:vue": "pnpm --filter './playgrounds/vue' dev",
    "dev:vue:build": "pnpm --filter './playgrounds/vue' build",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playgrounds/play && nuxt prepare docs && pnpm dev:vue:build",
    "docs": "nuxt dev docs",
    "docs:build": "nuxt build docs",
    "release": "release-it && npm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "movk-clean",
    "typecheck": "vue-tsc --noEmit && nuxt typecheck playgrounds/play && nuxt typecheck docs && cd playgrounds/vue && vue-tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@movk/core": "^1.3.0",
    "@turf/area": "^7.3.5",
    "@turf/bearing": "^7.3.5",
    "@turf/buffer": "^7.3.5",
    "@turf/circle": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/ellipse": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/sector": "^7.3.5",
    "@vueuse/core": "^14.3.0",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "gcoord": "^1.0.7",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0"
  },
  "devDependencies": {
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "happy-dom": "^20.10.4",
    "lottie-web": "^5.13.0",
    "mapbox-gl": "^3.24.1",
    "nuxt": "^4.4.8",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "unplugin": "^3.0.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  }
}
