# Mapbox / 天地图 token（文档内可交互地图示例所需）
NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_access_token
NUXT_PUBLIC_MAPBOX_TIANDITU_TOKEN=your_tianditu_tk
NUXT_TIANDITU_SEARCH_TOKEN=your_tianditu_search_tk
# Used to fetch docs content
NUXT_GITHUB_TOKEN=
# Used to access AI Gateway services
AI_GATEWAY_API_KEY=
# Optional: direct provider keys (any one enables AI Chat; matching prefix bypasses Gateway)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
ALIBABA_API_KEY=
ZHIPU_API_KEY=
# Optional: override endpoint/region as <PROVIDER>_BASE_URL, e.g. Alibaba China:
# ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
